<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane pannable="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="banana.republic.ui.StealDialogController">
    <content>
        <StackPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="1080.0" prefWidth="1920.0" styleClass="dialog-overlay" stylesheets="@../css/style.css">
            <VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="560.0" prefWidth="761.0" spacing="18.0" styleClass="dialog-box">
                <children>
                    <BorderPane>
                        <left>
                            <Label styleClass="dialog-title" text="Steal Resource" />
                        </left>
                        <right>
                            <Button onAction="#closeDialog" styleClass="close-btn" text="✕" />
                        </right>
                    </BorderPane>

                    <Label styleClass="theft-subtitle" text="Choose a player to steal from" />

                    <HBox alignment="CENTER" prefWidth="701.0" spacing="50.0">
                        <children>
                            <VBox fx:id="player1" alignment="CENTER" onMouseClicked="#selectPlayer1" prefHeight="200.0" prefWidth="150.0" styleClass="side-card-blue" visible="false">
                                <children>
                             <Label fx:id="player1Avatar" text="P">
                                <styleClass>
                                   <String fx:value="avatar-icon" />
                                   <String fx:value="avatar-blue" />
                                </styleClass>
                             </Label>
                                    <Label fx:id="player1Name" styleClass="player-name" text="Player 1">
                                <VBox.margin>
                                   <Insets bottom="20.0" />
                                </VBox.margin></Label>
                                    <Region prefHeight="10.0" />
                                    <Label fx:id="resCount1" styleClass="theft-resource-count" text="Resources: 0" />
                                    <Label styleClass="theft-random-item" text="Random item" wrapText="true" />
                                </children>
                            </VBox>

                            <VBox fx:id="player2" alignment="CENTER" onMouseClicked="#selectPlayer2" prefHeight="200.0" prefWidth="150.0" styleClass="side-card-green">
                                <children>
                             <Label fx:id="player2Avatar" text="P">
                                <styleClass>
                                   <String fx:value="avatar-icon" />
                                   <String fx:value="avatar-green" />
                                </styleClass>
                             </Label>
                                    <Label fx:id="player2Name" styleClass="player-name" text="Player 2">
                                <VBox.margin>
                                   <Insets bottom="20.0" />
                                </VBox.margin></Label>
                                    <Region prefHeight="10.0" />
                                    <Label fx:id="resCount2" styleClass="theft-resource-count" text="Resources: 0" />
                                    <Label styleClass="theft-random-item" text="Random item" wrapText="true" />
                                </children>
                            </VBox>

                            <VBox fx:id="player3" alignment="CENTER" onMouseClicked="#selectPlayer3" prefHeight="200.0" prefWidth="150.0" styleClass="side-card-orange">
                                <children>
                             <Label fx:id="player3Avatar" text="P">
                                <styleClass>
                                   <String fx:value="avatar-icon" />
                                   <String fx:value="avatar-orange" />
                                </styleClass>
                             </Label>
                                    <Label fx:id="player3Name" styleClass="player-name" text="Player 3">
                                <VBox.margin>
                                   <Insets bottom="20.0" />
                                </VBox.margin></Label>
                                    <Region prefHeight="10.0" />
                                    <Label fx:id="resCount3" styleClass="theft-resource-count" text="Resources: 0" />
                                    <Label styleClass="theft-random-item" text="Random item" wrapText="true" />
                                </children>
                            </VBox>
                       <VBox fx:id="player4" alignment="CENTER" onMouseClicked="#selectPlayer4" prefHeight="200.0" prefWidth="150.0" styleClass="side-card-red">
                          <children>
                             <Label fx:id="player4Avatar" text="P">
                                <styleClass>
                                   <String fx:value="avatar-icon" />
                                   <String fx:value="avatar-red" />
                                </styleClass>
                             </Label>
                             <Label fx:id="player4Name" styleClass="player-name" text="Player 4">
                                <VBox.margin>
                                   <Insets bottom="20.0" />
                                </VBox.margin>
                             </Label>
                             <Region prefHeight="10.0" />
                              <Label fx:id="resCount4" styleClass="theft-resource-count" text="Resources: 0" />
                              <Label styleClass="theft-random-item" text="Random item" wrapText="true" />
                          </children>
                       </VBox>
                        </children>
                    </HBox>

                    <HBox alignment="BOTTOM_RIGHT" spacing="15.0" VBox.vgrow="ALWAYS">
                        <children>
                            <Button onAction="#closeDialog" styleClass="btn-cancel" text="CANCEL" />
                            <Button onAction="#confirmSteal" styleClass="btn-submit" text="STEAL" />
                        </children>
                    </HBox>
                </children>
            </VBox>
        </StackPane>
    </content>
</ScrollPane>
